# =============================================================================
# CUTLINE - Environment variables (Purpose of this document is to explain what each variable does, Thanks me later dude)
# =============================================================================
# Copy this file to .env.local and fill in your API keys.
# See README for where to get each key. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Redis (required for job queue)
# -----------------------------------------------------------------------------
# BullMQ uses ioredis (TCP). Local: redis://localhost:6379
# Production: use a managed Redis (e.g. Upstash "Redis Connect" → ioredis URL, rediss://...)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# OpenRouter (LLM for Intent, Narrative, Shots, Script, Image query, Asset analysis)
# -----------------------------------------------------------------------------
# Get key: https://openrouter.ai → Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model for text (default: cheap Gemini Flash Lite). Or anthropic/claude-3.5-sonnet, openai/gpt-4o, etc.
# OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001
# Vision model for asset analysis (optional; defaults to OPENROUTER_MODEL)
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-lite-001

# -----------------------------------------------------------------------------
# TTS (text-to-speech)
# -----------------------------------------------------------------------------
# Provider: elevenlabs (default) or playht
TTS_PROVIDER=elevenlabs
# Voice ID - see provider docs (e.g. ElevenLabs voice library)
TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ElevenLabs - https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Set to true for Starter plan (MP3, speech-only). Unset for Pro (PCM + silence).
ELEVENLABS_USE_MP3=true

# PlayHT (only if TTS_PROVIDER=playht) - https://play.ht/app/account/api-access
PLAYHT_API_KEY=
PLAYHT_USER_ID=

# -----------------------------------------------------------------------------
# Asset upload storage
# -----------------------------------------------------------------------------
# local = disk (uploads/), s3 = AWS S3
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# S3 (only if STORAGE_TYPE=s3) - https://aws.amazon.com/console/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Image sourcing (at least one stock source required; images are mandatory)
# -----------------------------------------------------------------------------
# Unsplash (primary) - https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
# Pexels (fallback) - https://www.pexels.com/api/
PEXELS_API_KEY=
# OpenAI DALL·E 3 (AI fallback) - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Video duration and output limits
# -----------------------------------------------------------------------------
# Global max video duration in seconds (default 300, clamped 1-3600). Validation rejects
# durationSeconds above this; pipeline caps duration to this value.
# MAX_VIDEO_DURATION_SECONDS=300
# Optional: max output file size in MB. If set, job fails when rendered video exceeds it.
# Each output (including each variation) is checked.
# MAX_VIDEO_OUTPUT_MB=

# -----------------------------------------------------------------------------
# Cleanup (temp videos, uploads, per-job images)
# -----------------------------------------------------------------------------
CLEANUP_ENABLED=true
VIDEO_RETENTION_HOURS=24
UPLOAD_RETENTION_HOURS=24
CLEANUP_INTERVAL_HOURS=1
# Remove completed/failed jobs older than N days from Redis (0 = disable)
# JOB_RETENTION_DAYS=7
# Optional: require header X-Cleanup-Secret for POST /api/cleanup (recommended in prod)
# CLEANUP_SECRET=your_secret_here

# -----------------------------------------------------------------------------
# Usage / plan limits (credits and dashboard display)
# -----------------------------------------------------------------------------
# DEFAULT_TOKENS=10 - initial token balance per client (free plan)
# TOKENS_PER_VIDEO=10 - tokens deducted per completed video
# FREE_PLAN_VIDEOS_PER_MONTH=1 - videos limit (dashboard display)
# FREE_PLAN_API_CALLS_PER_MONTH=10000 - API calls limit (dashboard display)
# DISABLE_CREDITS_CHECK=true - skip credits/monthly limit check (e.g. local dev). Jobs can be created; worker may still deduct tokens.

# -----------------------------------------------------------------------------
# Admin (telemetry and /admin page)
# -----------------------------------------------------------------------------
# Required to access /admin and GET /api/telemetry, /api/telemetry/[jobId], /api/telemetry/stats.
# If unset, all admin/telemetry routes return 401. Set a strong secret in production.
# ADMIN_API_SECRET is an alias (either works).
# ADMIN_SECRET=your_admin_secret_here

# Optional: persist telemetry to a file so it survives restarts. Path relative to cwd.
# TELEMETRY_PERSIST_PATH is an alias. When set, loaded on first use, saved after each job ends; file capped to 500 jobs.
# TELEMETRY_FILE=.data/telemetry.json

# -----------------------------------------------------------------------------
# CORS (generate and related API routes only; admin/telemetry stay same-origin)
# -----------------------------------------------------------------------------
# Allow cross-origin requests from other domains/ports (e.g. a separate frontend).
# CORS_ORIGIN (single) or CORS_ORIGINS (comma-separated). If unset or empty, no
# CORS headers are set (same-origin only). Use "*" only in dev to allow any origin.
# Examples:
#   CORS_ORIGIN=https://app.example.com
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
#   CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=

# -----------------------------------------------------------------------------
# Idempotency (POST /api/generate - X-Idempotency-Key header)
# -----------------------------------------------------------------------------
# How long to remember idempotency keys (default 24, max 168 hours). Keys are in-memory only (lost on restart).
# IDEMPOTENCY_RETENTION_HOURS=24

# -----------------------------------------------------------------------------
# Rate limiting (per client: IP or X-Forwarded-For; uses same Redis as BullMQ)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
# POST /api/generate: RATE_LIMIT_MAX (or RATE_LIMIT_GENERATE) requests per RATE_LIMIT_WINDOW_SECONDS
# If unset: RATE_LIMIT_GENERATE (5) per 3600s (1h). Set both for per-minute limit, e.g. 10 per 60s
RATE_LIMIT_GENERATE=5
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_STATUS=60
RATE_LIMIT_GENERAL=100

# -----------------------------------------------------------------------------
# Talking object / Veo (video generation in talking_object mode)
# -----------------------------------------------------------------------------
# Google Gemini/Veo - https://aistudio.google.com/apikey (required for talking_object mode)
# GEMINI_API_KEY=
# Multiple Veo clips are concatenated with ffmpeg. If ffmpeg is not on PATH, set:
# FFMPEG_PATH=/path/to/ffmpeg
# Optional: path to an audio file (e.g. MP3) to mix as background music in talking_object videos
# BACKGROUND_MUSIC_PATH=

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# HeyGen API key for lip-sync (if using HeyGen integration)
# HEYGEN_API_KEY=

# -----------------------------------------------------------------------------
# Cost estimation (optional; defaults to 0 if unset)
# -----------------------------------------------------------------------------
# Set per your provider pricing for cost visibility in job results and logs.
# COST_PER_1K_TOKENS=0.001
# COST_PER_TTS_SECOND=0.05
# COST_PER_VIDEO_SECOND=0.10
# COST_PER_IMAGE_CALL=0.02

# -----------------------------------------------------------------------------
# Retry logic (transient failures: LLM, TTS, image fetch, Remotion render)
# -----------------------------------------------------------------------------
RETRY_ENABLED=true
RETRY_LLM_MAX=3
RETRY_TTS_MAX=3
RETRY_IMAGE_MAX=2
RETRY_RENDER_MAX=2
