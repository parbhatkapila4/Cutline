REDIS_URL=redis://localhost:6379

OPENROUTER_API_KEY=your_openrouter_api_key_here

TTS_PROVIDER=elevenlabs

TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

ELEVENLABS_API_KEY=

ELEVENLABS_USE_MP3=true

PLAYHT_API_KEY=

PLAYHT_USER_ID=

STORAGE_TYPE=local

UPLOAD_DIR=uploads

# Durable cross-host storage for finished videos. Required in the split deploy
# (app on Vercel, worker on Railway/Render/Fly): the worker uploads each MP4 to
# Vercel Blob so the app and browser can load it. Set the SAME token on BOTH the
# worker and the Vercel app. Leave empty for single-host/local dev (the worker
# then serves from public/temp directly).
BLOB_READ_WRITE_TOKEN=

UNSPLASH_ACCESS_KEY=

PEXELS_API_KEY=

OPENAI_API_KEY=

MAX_VIDEO_DURATION_SECONDS=300

MAX_VIDEO_OUTPUT_MB=

CLEANUP_ENABLED=true

VIDEO_RETENTION_HOURS=24

UPLOAD_RETENTION_HOURS=24

CLEANUP_INTERVAL_HOURS=1

JOB_RETENTION_DAYS=7

CLEANUP_SECRET=your_secret_here

DEFAULT_TOKENS=10

TOKENS_PER_VIDEO=10

FREE_PLAN_VIDEOS_PER_MONTH=1

FREE_PLAN_API_CALLS_PER_MONTH=1

RATE_LIMIT_ENABLED=true

RATE_LIMIT_GENERATE=5

RATE_LIMIT_UPLOAD=20

RATE_LIMIT_STATUS=60

RATE_LIMIT_GENERAL=100

GEMINI_API_KEY=

HEYGEN_API_KEY=

RETRY_ENABLED=true

RETRY_LLM_MAX=3

RETRY_TTS_MAX=3

RETRY_IMAGE_MAX=2

RETRY_RENDER_MAX=2
